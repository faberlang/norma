#!/usr/bin/env python3
"""Check Norma source ad routes against local host provider manifests and dispatch."""

from __future__ import annotations

import argparse
import contextlib
import io
import json
import re
import subprocess
import sys
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
WORKSPACE = ROOT.parent
HOST_PROVIDERS = WORKSPACE / "host-providers-rs"
EXPECTED_HOST_PROVIDERS_REV = "bed50e5"

PROVIDER_FAMILIES = ("aleator", "consolum", "processus", "solum", "tempus")

SOURCE_ONLY_EXCLUSIONS = {
    "processus:exi": "process exit is source-only until host exit has a protocol-visible terminal response",
}


def source_routes(root: Path = ROOT) -> dict[str, set[str]]:
    routes: dict[str, set[str]] = {family: set() for family in PROVIDER_FAMILIES}
    route_pattern = re.compile(r"\bad\s+'([^']+)'")
    for path in sorted((root / "src").rglob("*.fab")):
        text = path.read_text(encoding="utf-8")
        for route in route_pattern.findall(text):
            prefix, sep, _verb = route.partition(":")
            if sep and prefix in routes:
                routes[prefix].add(route)
    return routes


def manifest_routes(family: str, host_providers: Path = HOST_PROVIDERS) -> set[str]:
    manifest = host_providers / "crates" / family / "src" / "manifest.json"
    if not manifest.is_file():
        raise FileNotFoundError(f"missing provider manifest: {manifest}")
    payload = json.loads(manifest.read_text(encoding="utf-8"))
    return {call["route"] for call in payload["calls"]}


def _dispatch_match_body(source_text: str) -> str:
    marker = "match request.route.as_str()"
    start = source_text.find(marker)
    if start < 0:
        raise ValueError("missing dispatch match on request.route.as_str()")
    open_brace = source_text.find("{", start)
    if open_brace < 0:
        raise ValueError("missing dispatch match body")

    depth = 0
    for index in range(open_brace, len(source_text)):
        char = source_text[index]
        if char == "{":
            depth += 1
        elif char == "}":
            depth -= 1
            if depth == 0:
                return source_text[open_brace + 1 : index]
    raise ValueError("unterminated dispatch match body")


def dispatch_routes(family: str, host_providers: Path = HOST_PROVIDERS) -> set[str]:
    lib = host_providers / "crates" / family / "src" / "lib.rs"
    if not lib.is_file():
        raise FileNotFoundError(f"missing provider dispatch source: {lib}")
    match_body = _dispatch_match_body(lib.read_text(encoding="utf-8"))
    route_pattern = re.compile(rf'"({re.escape(family)}:[^"]+)"')
    return set(route_pattern.findall(match_body))


def git_short_head(repo: Path) -> str:
    result = subprocess.run(
        ["git", "-C", str(repo), "rev-parse", "--short=7", "HEAD"],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if result.returncode != 0:
        raise RuntimeError(
            "could not read git HEAD for provider evidence repo "
            f"{repo}: {result.stderr.strip()}"
        )
    return result.stdout.strip()


def dirty_provider_paths(repo: Path) -> list[str]:
    refresh = subprocess.run(
        ["git", "-C", str(repo), "update-index", "-q", "--refresh"],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if refresh.returncode != 0:
        raise RuntimeError(
            "could not refresh provider evidence git index "
            f"{repo}: {refresh.stderr.strip()}"
        )
    result = subprocess.run(
        ["git", "-C", str(repo), "status", "--porcelain=v1", "--untracked-files=all"],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if result.returncode != 0:
        raise RuntimeError(
            "could not inspect provider evidence git status "
            f"{repo}: {result.stderr.strip()}"
        )
    return [line for line in result.stdout.splitlines() if line.strip()]


def check_clean_provider_checkout(host_providers: Path) -> bool:
    dirty_paths = dirty_provider_paths(host_providers)
    if not dirty_paths:
        return True
    print(
        "audit-provider-route-claims: host-providers-rs evidence checkout is dirty; "
        "commit or clean provider manifest/dispatch changes before accepting pinned evidence",
        file=sys.stderr,
    )
    for path in dirty_paths:
        print(f"  {path}", file=sys.stderr)
    return False


def check_expected_revision(
    host_providers: Path,
    expected_rev: str | None,
) -> tuple[bool, str | None]:
    actual = git_short_head(host_providers)
    if expected_rev is None:
        return True, actual
    if actual != expected_rev:
        print(
            "audit-provider-route-claims: host-providers-rs revision mismatch: "
            f"expected {expected_rev}, got {actual}",
            file=sys.stderr,
        )
        return False, actual
    return True, actual


def run_audit(
    root: Path = ROOT,
    host_providers: Path = HOST_PROVIDERS,
    expected_rev: str | None = EXPECTED_HOST_PROVIDERS_REV,
) -> int:
    revision_ok, actual_rev = check_expected_revision(host_providers, expected_rev)
    clean_ok = check_clean_provider_checkout(host_providers)
    source = source_routes(root)
    status = 0 if revision_ok and clean_ok else 1

    if actual_rev is not None:
        print(f"host-providers-rs: rev={actual_rev}")

    for family in PROVIDER_FAMILIES:
        claimed = source[family]
        manifested = manifest_routes(family, host_providers)
        dispatched = dispatch_routes(family, host_providers)
        exclusions = {
            route
            for route in SOURCE_ONLY_EXCLUSIONS
            if route.startswith(f"{family}:")
        }
        unexpected_source_only = claimed - manifested - exclusions
        missing_from_source = manifested - claimed
        missing_from_dispatch = manifested - dispatched
        stale_exclusions = exclusions - (claimed - manifested)

        print(
            f"{family}: source={len(claimed)} manifest={len(manifested)} "
            f"dispatch={len(dispatched & manifested)} "
            f"excluded={len(exclusions - stale_exclusions)}"
        )

        for route in sorted(exclusions & (claimed - manifested)):
            print(f"  excluded source-only: {route} ({SOURCE_ONLY_EXCLUSIONS[route]})")

        if unexpected_source_only:
            status = 1
            print(
                f"audit-provider-route-claims: {family} source routes missing from manifest:",
                file=sys.stderr,
            )
            for route in sorted(unexpected_source_only):
                print(f"  {route}", file=sys.stderr)

        if missing_from_source:
            status = 1
            print(
                f"audit-provider-route-claims: {family} manifest routes missing from Norma source:",
                file=sys.stderr,
            )
            for route in sorted(missing_from_source):
                print(f"  {route}", file=sys.stderr)

        if missing_from_dispatch:
            status = 1
            print(
                f"audit-provider-route-claims: {family} manifest routes missing from provider dispatch:",
                file=sys.stderr,
            )
            for route in sorted(missing_from_dispatch):
                print(f"  {route}", file=sys.stderr)

        if stale_exclusions:
            status = 1
            print(
                f"audit-provider-route-claims: stale source-only exclusions for {family}:",
                file=sys.stderr,
            )
            for route in sorted(stale_exclusions):
                print(f"  {route}", file=sys.stderr)

    return status


def self_test() -> int:
    with tempfile.TemporaryDirectory() as tmp:
        root = Path(tmp) / "norma"
        host_providers = Path(tmp) / "host-providers-rs"
        (root / "src").mkdir(parents=True)
        for family in PROVIDER_FAMILIES:
            provider_src = host_providers / "crates" / family / "src"
            provider_src.mkdir(parents=True)
            routes = [f"{family}:one"]
            if family == "aleator":
                routes.append("aleator:missing")
            manifest = {
                "manifest_version": 1,
                "provider": family,
                "prefix": family,
                "calls": [{"route": route} for route in routes],
            }
            (provider_src / "manifest.json").write_text(
                json.dumps(manifest),
                encoding="utf-8",
            )
            dispatch_routes_text = [f'"{family}:one" => Ok(()),']
            (provider_src / "lib.rs").write_text(
                "\n".join(
                    [
                        "fn dispatch(request: RequestFrame) {",
                        "    match request.route.as_str() {",
                        *[f"        {line}" for line in dispatch_routes_text],
                        "        other => Err(other),",
                        "    }",
                        "}",
                    ]
                ),
                encoding="utf-8",
            )
        (root / "src" / "routes.fab").write_text(
            "\n".join(
                f"def {route.replace(':', '_')}() = ad '{route}' ()"
                for family in PROVIDER_FAMILIES
                for route in (
                    [f"{family}:one", "aleator:missing"]
                    if family == "aleator"
                    else (
                        [f"{family}:one", "processus:exi"]
                        if family == "processus"
                        else [f"{family}:one"]
                    )
                )
            ),
            encoding="utf-8",
        )
        subprocess.run(
            ["git", "-C", str(host_providers), "init", "-q"],
            check=True,
        )
        subprocess.run(
            ["git", "-C", str(host_providers), "add", "."],
            check=True,
        )
        subprocess.run(
            [
                "git",
                "-C",
                str(host_providers),
                "-c",
                "user.name=Norma Route Audit",
                "-c",
                "user.email=norma-route-audit@example.invalid",
                "commit",
                "-q",
                "-m",
                "self-test provider evidence",
            ],
            check=True,
        )
        actual_rev = git_short_head(host_providers)
        stdout = io.StringIO()
        stderr = io.StringIO()
        with contextlib.redirect_stdout(stdout), contextlib.redirect_stderr(stderr):
            status = run_audit(root, host_providers, expected_rev=actual_rev)
        if status == 0:
            print(
                "audit-provider-route-claims: self-test failed to reject a missing dispatch route",
                file=sys.stderr,
            )
            return 1
        if "aleator:missing" not in stderr.getvalue():
            print(
                "audit-provider-route-claims: self-test did not report the expected route",
                file=sys.stderr,
            )
            return 1
        manifest = host_providers / "crates" / "aleator" / "src" / "manifest.json"
        payload = json.loads(manifest.read_text(encoding="utf-8"))
        clean_payload = json.loads(json.dumps(payload))
        payload["calls"].append({"route": "aleator:dirty"})
        manifest.write_text(json.dumps(payload), encoding="utf-8")
        with contextlib.redirect_stdout(io.StringIO()), contextlib.redirect_stderr(
            stderr := io.StringIO()
        ):
            status = run_audit(root, host_providers, expected_rev=actual_rev)
        if status == 0:
            print(
                "audit-provider-route-claims: self-test failed to reject dirty provider evidence",
                file=sys.stderr,
            )
            return 1
        if "checkout is dirty" not in stderr.getvalue():
            print(
                "audit-provider-route-claims: self-test did not report dirty provider evidence",
                file=sys.stderr,
            )
            return 1
        manifest.write_text(json.dumps(clean_payload), encoding="utf-8")
        with contextlib.redirect_stdout(io.StringIO()), contextlib.redirect_stderr(
            stderr := io.StringIO()
        ):
            status = run_audit(root, host_providers, expected_rev="0000000")
        if status == 0:
            print(
                "audit-provider-route-claims: self-test failed to reject a revision mismatch",
                file=sys.stderr,
            )
            return 1
        if "revision mismatch" not in stderr.getvalue():
            print(
                "audit-provider-route-claims: self-test did not report the expected revision mismatch",
                file=sys.stderr,
            )
            return 1
    print("audit-provider-route-claims: self-test passed")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--self-test",
        action="store_true",
        help="run internal negative fixtures for missing dispatch, dirty provider evidence, and revision mismatch",
    )
    parser.add_argument(
        "--host-providers",
        type=Path,
        default=HOST_PROVIDERS,
        help="path to the sibling host-providers-rs evidence checkout",
    )
    parser.add_argument(
        "--expected-rev",
        default=EXPECTED_HOST_PROVIDERS_REV,
        help="expected short host-providers-rs git revision for the evidence boundary",
    )
    args = parser.parse_args()
    if args.self_test:
        return self_test()
    return run_audit(host_providers=args.host_providers, expected_rev=args.expected_rev)


if __name__ == "__main__":
    raise SystemExit(main())
