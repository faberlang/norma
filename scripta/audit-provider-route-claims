#!/usr/bin/env python3
"""Check Norma source ad routes against local host provider manifests and dispatch."""

from __future__ import annotations

import argparse
import contextlib
import io
import json
import re
import sys
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
WORKSPACE = ROOT.parent
HOST_PROVIDERS = WORKSPACE / "host-providers-rs"

PROVIDER_FAMILIES = ("aleator", "consolum", "processus", "solum", "tempus")

SOURCE_ONLY_EXCLUSIONS = {
    "processus:exi": "process exit is source-only until host exit has a protocol-visible terminal response",
}


def source_routes(root: Path = ROOT) -> dict[str, set[str]]:
    routes: dict[str, set[str]] = {family: set() for family in PROVIDER_FAMILIES}
    route_pattern = re.compile(r"\bad\s+'([^']+)'")
    for path in sorted((root / "src").rglob("*.fab")):
        text = path.read_text(encoding="utf-8")
        for route in route_pattern.findall(text):
            prefix, sep, _verb = route.partition(":")
            if sep and prefix in routes:
                routes[prefix].add(route)
    return routes


def manifest_routes(family: str, host_providers: Path = HOST_PROVIDERS) -> set[str]:
    manifest = host_providers / "crates" / family / "src" / "manifest.json"
    if not manifest.is_file():
        raise FileNotFoundError(f"missing provider manifest: {manifest}")
    payload = json.loads(manifest.read_text(encoding="utf-8"))
    return {call["route"] for call in payload["calls"]}


def _dispatch_match_body(source_text: str) -> str:
    marker = "match request.route.as_str()"
    start = source_text.find(marker)
    if start < 0:
        raise ValueError("missing dispatch match on request.route.as_str()")
    open_brace = source_text.find("{", start)
    if open_brace < 0:
        raise ValueError("missing dispatch match body")

    depth = 0
    for index in range(open_brace, len(source_text)):
        char = source_text[index]
        if char == "{":
            depth += 1
        elif char == "}":
            depth -= 1
            if depth == 0:
                return source_text[open_brace + 1 : index]
    raise ValueError("unterminated dispatch match body")


def dispatch_routes(family: str, host_providers: Path = HOST_PROVIDERS) -> set[str]:
    lib = host_providers / "crates" / family / "src" / "lib.rs"
    if not lib.is_file():
        raise FileNotFoundError(f"missing provider dispatch source: {lib}")
    match_body = _dispatch_match_body(lib.read_text(encoding="utf-8"))
    route_pattern = re.compile(rf'"({re.escape(family)}:[^"]+)"')
    return set(route_pattern.findall(match_body))


def run_audit(root: Path = ROOT, host_providers: Path = HOST_PROVIDERS) -> int:
    source = source_routes(root)
    status = 0

    for family in PROVIDER_FAMILIES:
        claimed = source[family]
        manifested = manifest_routes(family, host_providers)
        dispatched = dispatch_routes(family, host_providers)
        exclusions = {
            route
            for route in SOURCE_ONLY_EXCLUSIONS
            if route.startswith(f"{family}:")
        }
        unexpected_source_only = claimed - manifested - exclusions
        missing_from_source = manifested - claimed
        missing_from_dispatch = manifested - dispatched
        stale_exclusions = exclusions - (claimed - manifested)

        print(
            f"{family}: source={len(claimed)} manifest={len(manifested)} "
            f"dispatch={len(dispatched & manifested)} "
            f"excluded={len(exclusions - stale_exclusions)}"
        )

        for route in sorted(exclusions & (claimed - manifested)):
            print(f"  excluded source-only: {route} ({SOURCE_ONLY_EXCLUSIONS[route]})")

        if unexpected_source_only:
            status = 1
            print(
                f"audit-provider-route-claims: {family} source routes missing from manifest:",
                file=sys.stderr,
            )
            for route in sorted(unexpected_source_only):
                print(f"  {route}", file=sys.stderr)

        if missing_from_source:
            status = 1
            print(
                f"audit-provider-route-claims: {family} manifest routes missing from Norma source:",
                file=sys.stderr,
            )
            for route in sorted(missing_from_source):
                print(f"  {route}", file=sys.stderr)

        if missing_from_dispatch:
            status = 1
            print(
                f"audit-provider-route-claims: {family} manifest routes missing from provider dispatch:",
                file=sys.stderr,
            )
            for route in sorted(missing_from_dispatch):
                print(f"  {route}", file=sys.stderr)

        if stale_exclusions:
            status = 1
            print(
                f"audit-provider-route-claims: stale source-only exclusions for {family}:",
                file=sys.stderr,
            )
            for route in sorted(stale_exclusions):
                print(f"  {route}", file=sys.stderr)

    return status


def self_test() -> int:
    with tempfile.TemporaryDirectory() as tmp:
        root = Path(tmp) / "norma"
        host_providers = Path(tmp) / "host-providers-rs"
        (root / "src").mkdir(parents=True)
        for family in PROVIDER_FAMILIES:
            provider_src = host_providers / "crates" / family / "src"
            provider_src.mkdir(parents=True)
            routes = [f"{family}:one"]
            if family == "aleator":
                routes.append("aleator:missing")
            manifest = {
                "manifest_version": 1,
                "provider": family,
                "prefix": family,
                "calls": [{"route": route} for route in routes],
            }
            (provider_src / "manifest.json").write_text(
                json.dumps(manifest),
                encoding="utf-8",
            )
            dispatch_routes_text = [f'"{family}:one" => Ok(()),']
            (provider_src / "lib.rs").write_text(
                "\n".join(
                    [
                        "fn dispatch(request: RequestFrame) {",
                        "    match request.route.as_str() {",
                        *[f"        {line}" for line in dispatch_routes_text],
                        "        other => Err(other),",
                        "    }",
                        "}",
                    ]
                ),
                encoding="utf-8",
            )
        (root / "src" / "routes.fab").write_text(
            "\n".join(
                f"def {route.replace(':', '_')}() = ad '{route}' ()"
                for family in PROVIDER_FAMILIES
                for route in (
                    [f"{family}:one", "aleator:missing"]
                    if family == "aleator"
                    else (
                        [f"{family}:one", "processus:exi"]
                        if family == "processus"
                        else [f"{family}:one"]
                    )
                )
            ),
            encoding="utf-8",
        )
        stdout = io.StringIO()
        stderr = io.StringIO()
        with contextlib.redirect_stdout(stdout), contextlib.redirect_stderr(stderr):
            status = run_audit(root, host_providers)
        if status == 0:
            print(
                "audit-provider-route-claims: self-test failed to reject a missing dispatch route",
                file=sys.stderr,
            )
            return 1
        if "aleator:missing" not in stderr.getvalue():
            print(
                "audit-provider-route-claims: self-test did not report the expected route",
                file=sys.stderr,
            )
            return 1
    print("audit-provider-route-claims: self-test passed")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--self-test",
        action="store_true",
        help="run an internal negative fixture for missing manifest dispatch coverage",
    )
    args = parser.parse_args()
    if args.self_test:
        return self_test()
    return run_audit()


if __name__ == "__main__":
    raise SystemExit(main())
