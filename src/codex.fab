# URL ENCODING (percent-encoding)
# =========================================================================

# Encode text for URL (percent-encoding)
functio url(textus data) → textus {
    mori "norma:codex.url is deferred pending Stage 2 dispatch"
}

# Decode URL-encoded text
functio deUrl(textus data) → textus {
    mori "norma:codex.deUrl is deferred pending Stage 2 dispatch"
