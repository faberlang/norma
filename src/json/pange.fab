# json/pange.fab — JSON serialization facade
#
# The compiler/runtime-owned formal `json` conversio is the single codec
# authority. This module exists so direct `norma:json/pange` imports share the
# same path as the top-level `norma:json.pange` facade.

functio pange(json documentum) → textus {
    redde documentum ↦ textus
}
