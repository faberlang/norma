# json/solve.fab — JSON parse facade
#
# The compiler/runtime-owned formal `json` conversio is the single codec
# authority. This module exists so direct `norma:json/solve` imports share the
# same path as the top-level `norma:json.solve` facade.

functio solve(textus wire) → json ⇥ textus {
    redde wire ↦ json
}

functio tempta(textus wire) → json ∪ nihil {
    fac {
        redde solve(wire)
    }
    cape err {
        redde nihil
    }
}
