# json/cursor.fab — parser cursor type
#
# Position-threading genus for the recursive-descent parser in solve.fab.
# Faber has no tuple returns, so each _x parser returns a Resultus carrying
# both the parsed valor and the next scan index. Mirrors the caelum pattern
# of placing a shared value type in its own submodule file.

genus Resultus {
    valor v
    numerus i
}
